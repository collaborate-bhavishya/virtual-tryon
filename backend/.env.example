PORT=5001

# --- Google AI Studio Mode ---
# Standard API Key from https://aistudio.google.com/
GEMINI_API_KEY=

# --- Vertex AI (GCP) Mode ---
# Set to 'true' to enable Vertex AI authentication (uses GCP IAM/Application Default Credentials)
VERTEX_AI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Optional Model Override ---
# Defaults:
# - AI Studio: imagen-4.0-generate-001
# - Vertex AI: imagen-3.0-generate-002
# Change to a custom model string if required:
IMAGEN_MODEL=
